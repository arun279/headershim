{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "overrides": [
    {
      "includes": ["**/tokens.css"],
      "formatter": { "enabled": false },
      "linter": {
        "rules": {
          "complexity": { "noImportantStyles": "off" }
        }
      }
    }
  ]
}
