[
  {
    "title": "Development",
    "shortTitle": "DEV",
    "backgroundColor": "#2ea9af",
    "version": 2,
    "headers": [
      {
        "enabled": true,
        "name": "Accept",
        "value": "application/json",
        "appendMode": "append",
        "comment": "accepted response formats"
      },
      {
        "enabled": false,
        "name": "X-Debug",
        "value": "on",
        "appendMode": "append",
        "comment": "debug switch"
      },
      {
        "enabled": true,
        "name": "Authorization",
        "value": "Bearer {{uuid}} from {{url_hostname}} at {{timestamp}}",
        "comment": "literal token header"
      }
    ],
    "respHeaders": [
      {
        "enabled": true,
        "name": "Cache-Control",
        "value": "no-store",
        "operation": "set",
        "comment": "disable caching"
      },
      {
        "enabled": false,
        "name": "Vary",
        "value": "x-debug",
        "operation": "append",
        "comment": "vary marker"
      },
      {
        "enabled": true,
        "name": "Server",
        "operation": "remove",
        "comment": "hide server"
      }
    ],
    "cookieHeaders": [
      {
        "enabled": true,
        "name": "session",
        "value": "preview",
        "comment": "preview cookie"
      }
    ],
    "setCookieHeaders": [
      {
        "enabled": false,
        "name": "theme",
        "value": "dark",
        "comment": "theme cookie"
      }
    ],
    "cspHeaders": [
      {
        "enabled": true,
        "name": "connect-src",
        "value": "'self' https://api.example.com",
        "comment": "api policy"
      }
    ],
    "urlFilters": [
      {
        "enabled": true,
        "urlRegex": "^https://(?:www\\.)?example\\.com/"
      }
    ],
    "resourceFilters": [
      {
        "enabled": true,
        "resourceType": [
          "main_frame",
          "sub_frame",
          "xmlhttprequest",
          "script",
          "stylesheet",
          "image",
          "font",
          "media",
          "websocket",
          "ping"
        ]
      },
      {
        "enabled": false,
        "resourceType": ["object"]
      }
    ],
    "excludeUrlFilters": [
      {
        "enabled": true,
        "urlRegex": "logout"
      },
      {
        "enabled": false,
        "urlRegex": "health"
      }
    ],
    "initiatorDomainFilters": [
      {
        "enabled": true,
        "domain": "app.example.com"
      },
      {
        "enabled": false,
        "domain": "admin.example.com"
      }
    ],
    "tabFilters": [
      {
        "enabled": true,
        "tabId": 42
      }
    ],
    "tabGroupFilters": [
      {
        "enabled": true,
        "tabGroupId": 7
      }
    ],
    "windowFilters": [
      {
        "enabled": true,
        "windowId": 3
      }
    ],
    "timeFilters": [
      {
        "enabled": true,
        "name": "business hours"
      }
    ],
    "urlReplacements": [
      {
        "enabled": true,
        "name": "^https://old.example.com/",
        "value": "https://new.example.com/"
      }
    ]
  }
]
