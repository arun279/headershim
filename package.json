{
  "name": "headershim",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "icons": "node scripts/render-icons.mjs",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:lint": "biome ci .",
    "check:types": "tsc --noEmit",
    "check:test": "vitest run --coverage",
    "check:knip": "knip",
    "check:dup": "jscpd",
    "check:size": "pnpm build && size-limit",
    "check:manifest": "pnpm build && node scripts/manifest-policy.mjs",
    "check:platform": "paths='src/core'; if [ -d src/ui ]; then paths=\"$paths src/ui\"; fi; if grep -R -n -E 'browser[.]|chrome[.]' $paths; then echo 'Extension API references must stay in platform adapters or entrypoints.' >&2; exit 1; fi",
    "check:verify": "if grep -R -n -E 'getMatchedRules\\(\\s*\\)' src entrypoints; then echo 'Verify must always pass an explicit tabId to getMatchedRules.' >&2; exit 1; fi",
    "check:icons": "node scripts/render-icons.mjs --check",
    "check:self-contained": "node scripts/check-self-contained.mjs",
    "check": "biome ci . && tsc --noEmit && vitest run --coverage && knip && jscpd && pnpm build && node scripts/manifest-policy.mjs && size-limit && pnpm check:platform && pnpm check:verify && pnpm check:self-contained",
    "e2e": "pnpm build && playwright test",
    "e2e:packed:pack": "pnpm build && node e2e/packed/pack.mjs",
    "e2e:packed:selfcheck": "node e2e/packed/selfcheck.mjs",
    "e2e:packed": "playwright test -c playwright.packed.config.ts",
    "postinstall": "wxt prepare",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {},
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@size-limit/file": "^12.1.0",
    "@tsconfig/strictest": "^2.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "@webext-core/fake-browser": "^1.5.2",
    "happy-dom": "^20.10.6",
    "jscpd": "^5.0.11",
    "knip": "^6.24.0",
    "preact": "^10.29.7",
    "size-limit": "^12.1.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  },
  "size-limit": [
    {
      "name": "Background",
      "path": ".output/chrome-mv3/background.js",
      "limit": "5.25 kB"
    },
    {
      "name": "Shared UI runtime",
      "path": ".output/chrome-mv3/chunks/glyphs-*.js",
      "limit": "21.5 kB"
    },
    {
      "name": "Popup",
      "path": ".output/chrome-mv3/chunks/popup-*.js",
      "limit": "23 kB"
    },
    {
      "name": "Options",
      "path": ".output/chrome-mv3/chunks/options-*.js",
      "limit": "7.5 kB"
    }
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ],
    "overrides": {
      "shell-quote": ">=1.8.4",
      "tmp": ">=0.2.6"
    }
  }
}
