{
  "name": "headershim",
  "version": "0.1.0",
  "description": "Modify HTTP request and response headers with scoped rules and switchable profiles.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arun279/headershim.git"
  },
  "homepage": "https://github.com/arun279/headershim#readme",
  "bugs": {
    "url": "https://github.com/arun279/headershim/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:e2e:hostaccess": "E2E_HOST_ACCESS=1 wxt build",
    "icons": "node scripts/render-icons.mjs",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:lint": "biome ci .",
    "check:types": "tsc --noEmit",
    "check:test": "vitest run --coverage",
    "check:knip": "knip",
    "check:knip:production": "knip --production --include files",
    "check:dup": "jscpd",
    "check:size": "pnpm build && size-limit",
    "check:manifest": "pnpm build && node scripts/manifest-policy.mjs",
    "check:platform": "paths='src/core'; if [ -d src/ui ]; then paths=\"$paths src/ui\"; fi; if grep -R -n -E 'browser[.]|chrome[.]' $paths; then echo 'Extension API references must stay in platform adapters or entrypoints.' >&2; exit 1; fi",
    "check:icons": "node scripts/render-icons.mjs --check",
    "check:self-contained": "node scripts/check-self-contained.mjs",
    "check:em-dash": "node scripts/check-em-dash.mjs",
    "check": "biome ci . && tsc --noEmit && vitest run --coverage && knip && knip --production --include files && jscpd && pnpm build && node scripts/manifest-policy.mjs && size-limit && pnpm check:platform && pnpm check:icons && pnpm check:self-contained && pnpm check:em-dash",
    "e2e": "pnpm build && pnpm build:e2e:hostaccess && playwright test",
    "e2e:packed:pack": "pnpm build && node e2e/packed/pack.mjs",
    "e2e:packed:selfcheck": "node e2e/packed/selfcheck.mjs",
    "e2e:packed": "playwright test -c playwright.packed.config.ts",
    "postinstall": "wxt prepare",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {},
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@size-limit/file": "^12.1.0",
    "@tsconfig/strictest": "^2.0.8",
    "@vitest/coverage-v8": "^4.1.9",
    "@webext-core/fake-browser": "^1.5.2",
    "happy-dom": "^20.10.6",
    "jscpd": "^5.0.11",
    "knip": "^6.24.0",
    "preact": "^10.29.7",
    "size-limit": "^12.1.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  },
  "size-limit": [
    {
      "name": "Background",
      "path": ".output/chrome-mv3/background.js",
      "limit": "5.25 kB"
    },
    {
      "name": "Shared UI runtime",
      "path": ".output/chrome-mv3/chunks/readout-*.js",
      "limit": "15 kB"
    },
    {
      "name": "Popup",
      "path": ".output/chrome-mv3/chunks/popup-*.js",
      "limit": "23 kB"
    },
    {
      "name": "Options initial load",
      "path": [
        ".output/chrome-mv3/options.html",
        ".output/chrome-mv3/theme-bootstrap.js",
        ".output/chrome-mv3/chunks/options-*.js",
        ".output/chrome-mv3/chunks/readout-*.js",
        ".output/chrome-mv3/chunks/Segmented-*.js",
        ".output/chrome-mv3/chunks/headers-*.js",
        ".output/chrome-mv3/assets/readout-*.css",
        ".output/chrome-mv3/assets/Segmented-*.css",
        ".output/chrome-mv3/assets/options-*.css"
      ],
      "limit": "45 kB"
    },
    {
      "name": "Options rule editor",
      "path": [
        ".output/chrome-mv3/chunks/RuleEditor-*.js",
        ".output/chrome-mv3/assets/RuleEditor-*.css"
      ],
      "limit": "12 kB"
    }
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "spawn-sync"
    ],
    "overrides": {
      "adm-zip": ">=0.6.0",
      "esbuild": ">=0.28.1",
      "shell-quote": ">=1.8.4",
      "tmp": ">=0.2.6",
      "uuid": ">=11.1.1"
    }
  }
}
